# ── Google Cloud / Vertex AI ──────────────────────────────────────────────────
# Your GCP Project ID (visible in Cloud Console top bar)
GOOGLE_CLOUD_PROJECT_ID=tryinstantfit

# Region — gemini-3-pro-image-preview is available in us-central1
VERTEX_LOCATION=us-central1

# Service account key JSON
# In Vercel: paste the entire contents of the downloaded .json file as one line
GOOGLE_CLOUD_KEY_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# GCS bucket for storing try-on result images
GOOGLE_CLOUD_BUCKET_NAME=tryinstantfit-tryons

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://tryinstantfit-api.vercel.app
